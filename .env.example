# ─────────────────────────────────────────────────────────────────────────────
# Monarch MCP Server — environment configuration
# Copy to .env and fill in. NEVER commit your real .env.
# ─────────────────────────────────────────────────────────────────────────────

# ── Transport ───────────────────────────────────────────────────────────────
# stdio = local Claude Desktop/Code (default in code).
# http  = remote Streamable HTTP service (default in the container).
TRANSPORT=http
# Port the container serves plain HTTP on (TLS terminates at your proxy).
PORT=8000
# Loopback host port published by docker-compose (host reverse proxy targets it).
HOST_PORT=8000
# Path the Streamable HTTP MCP endpoint is served on. Default "/" so the
# resource id, the Claude connector URL, and the request path all coincide
# (Claude posts MCP traffic to the connector origin). Set to /mcp for a sub-path.
MCP_PATH=/
# Interface to bind. 0.0.0.0 inside a container is fine.
HOST=0.0.0.0
# Per-IP requests/minute for the HTTP transport (0 disables). /healthz is exempt.
RATE_LIMIT_PER_MINUTE=120

# ── Monarch headless login ──────────────────────────────────────────────────
# Used only when there is no persisted session. MFA is completed automatically
# from the TOTP secret below, so login is fully non-interactive.
MONARCH_EMAIL=
MONARCH_PASSWORD=
# Base32 TOTP secret from Monarch's authenticator-app setup ("manual entry" key).
MONARCH_MFA_SECRET=
# Where the Monarch session token is persisted (mounted volume in the container).
SESSION_STORE_PATH=/data/monarch-session

# ── OAuth 2.0 Resource Server (MCP auth spec 2025-06-18) ────────────────────
# This server validates IdP-issued bearer JWTs; it never hosts the auth flow.
# Leave all three blank to run unauthenticated (local/stdio dev only).
#
# OAUTH_ISSUER   : the "iss" your IdP stamps into tokens (trailing slash matters).
# OAUTH_AUDIENCE : THIS server's resource id — the "aud" tokens must carry.
#                  Set it to your public HTTPS URL (== PUBLIC_URL). This is the
#                  #1 thing to get right; a mismatch yields 401 on every call.
# OAUTH_JWKS_URI : the IdP JWKS endpoint used to verify token signatures.
OAUTH_ISSUER=
OAUTH_AUDIENCE=
OAUTH_JWKS_URI=

# Public HTTPS URL of this server (advertised in RFC 9728 metadata). Defaults
# OAUTH_AUDIENCE when that is unset.
PUBLIC_URL=https://monarch-mcp.example.com

# Scopes. Reads require the read scope (enforced on every request); mutating
# tools additionally require the write scope.
REQUIRED_READ_SCOPE=monarch:read
REQUIRED_WRITE_SCOPE=monarch:write

# ── Security ────────────────────────────────────────────────────────────────
# true  = mutating tools are not registered at all (safe default).
# false = mutating tools available, gated by the write scope.
READ_ONLY=true
